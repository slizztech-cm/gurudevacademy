@model List<StudyPdf>
@{
    var cats = ViewBag.Categories as List<CourseCategory> ?? new();
}
<div class="panel">
    <div class="panel-head"><h2>➕ Add Study PDF</h2></div>
    <div class="panel-body">
        <form method="post" action="/admin/study/create" enctype="multipart/form-data" class="adm-form">
            @Html.AntiForgeryToken()
            <div class="row2">
                <div class="form-group"><label>Title *</label><input name="Title" class="form-control" required /></div>
                <div class="form-group">
                    <label>Category</label>
                    <select name="CategoryId" class="form-control">
                        <option value="">— None —</option>
                        @foreach (var c in cats) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </div>
            </div>
            <div class="form-group"><label>Description</label><input name="Description" class="form-control" /></div>
            <div class="row2">
                <div class="form-group"><label>Subject</label><input name="Subject" class="form-control" /></div>
                <div class="form-group"><label>Upload PDF</label><input name="file" type="file" accept="application/pdf" class="form-control" /></div>
            </div>
            <div class="form-group"><label>…or external File URL</label><input name="FileUrl" class="form-control" placeholder="https://..." /></div>
            <div class="row2">
                <div class="form-group" style="display:flex;align-items:flex-end"><label style="margin:0"><input type="checkbox" name="IsFree" value="true" checked /><input type="hidden" name="IsFree" value="false" /> Free</label></div>
                <div class="form-group"><label>Price (₹, if paid)</label><input name="Price" type="number" step="0.01" class="form-control" /></div>
            </div>
            <input type="hidden" name="IsActive" value="true" />
            <button class="btn btn-primary">Add Material</button>
        </form>
    </div>
</div>

<div class="panel">
    <div class="panel-head"><h2>All Study PDFs (@Model.Count)</h2></div>
    <div class="panel-body">
        <div class="tbl-wrap">
            <table class="tbl">
                <thead><tr><th>Title</th><th>Subject</th><th>Type</th><th>Downloads</th><th>Action</th></tr></thead>
                <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Title<br><small class="muted">@p.Description</small></td>
                        <td>@p.Subject</td>
                        <td>@(p.IsFree ? "Free" : $"₹{p.Price}")</td>
                        <td>@p.DownloadCount</td>
                        <td>
                            <div class="row-actions">
                                <a href="@p.FileUrl" target="_blank" class="btn btn-ghost btn-sm">Open</a>
                                <details>
                                    <summary class="btn btn-ghost btn-sm">Edit</summary>
                                    <form method="post" action="/admin/study/update" enctype="multipart/form-data" class="adm-form" style="margin-top:.6rem;min-width:280px">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@p.Id" />
                                        <label>Title</label>
                                        <input name="Title" class="form-control" value="@p.Title" />
                                        <label>Category</label>
                                        <select name="CategoryId" class="form-control">
                                            <option value="">— None —</option>
                                            @foreach (var c in cats) { <option value="@c.Id" selected="@(c.Id == p.CategoryId)">@c.Name</option> }
                                        </select>
                                        <label>Subject</label>
                                        <input name="Subject" class="form-control" value="@p.Subject" />
                                        <label>Description</label>
                                        <input name="Description" class="form-control" value="@p.Description" />
                                        <label><input type="checkbox" name="IsFree" value="true" checked="@p.IsFree" /><input type="hidden" name="IsFree" value="false" /> Free</label>
                                        <label>Price (₹, if paid)</label>
                                        <input name="Price" type="number" step="0.01" class="form-control" value="@p.Price" />
                                        <label>Replace PDF (optional)</label>
                                        <input name="file" type="file" accept="application/pdf" class="form-control" />
                                        <label>…or change File URL</label>
                                        <input name="FileUrl" class="form-control" value="@p.FileUrl" />
                                        <button class="btn btn-primary btn-sm" style="margin-top:.5rem">Save</button>
                                    </form>
                                </details>
                                <form method="post" action="/admin/study/delete/@p.Id" data-confirm="Delete this material?">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (Model.Count == 0) { <p class="muted mt">No study material yet.</p> }
    </div>
</div>
