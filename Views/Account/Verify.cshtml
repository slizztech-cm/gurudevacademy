@{
    ViewData["Title"] = "Verify Email — Gurudev Defence Academy";
    var email = ViewBag.Email as string;
}
<div class="auth-wrap">
    <div style="width:100%;max-width:400px">
        <div class="auth-logo">
            <img src="~/img/logo.svg" alt="logo" />
            <h1>Verify your email</h1>
            <p>We sent a 6-digit code @(string.IsNullOrEmpty(email) ? "to your email" : $"to {email}")</p>
        </div>
        <form method="post" action="/account/verify" class="form-card">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-err">@Html.ValidationSummary(true)</div>
            }
            <div class="form-group">
                <label>Verification Code</label>
                <input name="otp" class="form-control" inputmode="numeric" maxlength="6"
                       placeholder="000000" style="letter-spacing:8px;text-align:center;font-size:1.4rem" autofocus />
            </div>
            <button type="submit" class="btn btn-primary btn-block">Verify & Create Account →</button>
        </form>
        <p class="auth-alt"><a href="/account/register">← Use a different email</a></p>
    </div>
</div>
