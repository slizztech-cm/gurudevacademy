@model JoinRequestViewModel
@{
    var courses = ViewBag.Courses as List<Course> ?? new();
}
<section class="hero" style="padding:3rem 0">
    <div class="container center">
        <span class="hero-badge">📝 Admission Enquiry</span>
        <h1>Join a Course</h1>
        <p style="margin:1rem auto 0">Fill the form and our team will reach out with all the details.</p>
    </div>
</section>

<section style="padding-top:1rem">
    <div class="container">
        @if (TempData["Ok"] is string ok) { <div class="form-card" style="margin-bottom:1rem"><div class="alert alert-ok">@ok</div></div> }
        <form method="post" action="/join" class="form-card">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Full Name *</label>
                <input asp-for="Name" class="form-control" placeholder="Your name" />
                <span asp-validation-for="Name" class="field-err"></span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Phone *</label>
                    <input asp-for="Phone" class="form-control" placeholder="10-digit mobile" />
                    <span asp-validation-for="Phone" class="field-err"></span>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="optional" />
                    <span asp-validation-for="Email" class="field-err"></span>
                </div>
            </div>
            <div class="form-group">
                <label>Interested Course</label>
                <select asp-for="CourseName" class="form-control">
                    <option value="">— Select a course —</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.Name" selected="@(Model.CourseName == c.Name)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Message</label>
                <textarea asp-for="Message" class="form-control" placeholder="Any questions or preferred timing?"></textarea>
            </div>
            <button type="submit" class="btn btn-gold btn-block">Submit Enquiry →</button>
        </form>
    </div>
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
